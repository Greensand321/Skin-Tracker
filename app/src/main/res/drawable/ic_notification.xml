<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon — monochrome (white on transparent) skin cross-section.
    Three horizontal layers (epidermis, dermis, subcutis) with two hair follicles,
    matching the skin_square.jpeg branding.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer skin-block outline — rounded top corners, flat bottom. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.8"
        android:pathData="M2,7 C2,5.9 2.9,5 4,5 L20,5 C21.1,5 22,5.9 22,7 L22,20 C22,21.1 21.1,22 20,22 L4,22 C2.9,22 2,21.1 2,20 Z" />
    <!-- Epidermis / dermis divider. -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:pathData="M2,12 L22,12" />
    <!-- Dermis / subcutis divider. -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:pathData="M2,17 L22,17" />
    <!-- Hair follicle — left. -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:pathData="M8,5 C7.5,3.5 9,2 8.5,1" />
    <!-- Hair follicle — right. -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:pathData="M16,5 C16.5,3.5 15,2.5 16,1.5" />
</vector>
