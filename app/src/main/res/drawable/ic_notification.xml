<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon — must be monochrome (white on transparent) for Android's
    tinting system. Avocado pear outline with pit hole using even-odd fill rule,
    matching the app's avocado branding from ic_launcher_foreground.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!--
        Outer avocado pear shape + inner pit circle as a single even-odd path,
        so the pit appears as a transparent hole through the white fill.
    -->
    <path
        android:fillColor="@android:color/white"
        android:fillType="evenOdd"
        android:pathData="
            M12,1.5
            C9.5,1.5 7,4 7,7.5
            C7,10.5 6,12.5 5.5,14.5
            C4.5,18 6,22.5 12,22.5
            C18,22.5 19.5,18 18.5,14.5
            C18,12.5 17,10.5 17,7.5
            C17,4 14.5,1.5 12,1.5 Z
            M12,10.5
            C10.3,10.5 9,11.8 9,13.5
            C9,15.2 10.3,16.5 12,16.5
            C13.7,16.5 15,15.2 15,13.5
            C15,11.8 13.7,10.5 12,10.5 Z" />
</vector>
